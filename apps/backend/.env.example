# --- Server ---
# Porta su cui Express resta in ascolto.
PORT=3000

# --- Database (MySQL) ---
# Credenziali di connessione al database MySQL.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=

# --- Autenticazione (JWT) ---
# Chiave segreta usata per firmare/verificare i JSON Web Token (jsonwebtoken).
# Deve essere una stringa lunga, casuale e mai committata nel repository.
# Generane una nuova per ogni ambiente con, ad esempio:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
